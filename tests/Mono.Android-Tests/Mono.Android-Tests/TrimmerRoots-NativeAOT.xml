<linker>
  <!--
    NUnit 3.13.x's `EquatablesComparer.GetEquatableImplementations` reflects on
    `IEquatable<T>` implementations of the values being compared:

      type.GetInterfaces()
          .Where(@i => @i.IsGenericType && @i.GetGenericTypeDefinition() == typeof(IEquatable<>))
          .Select(@i => @i.GetGenericArguments()[0])

    Under NativeAOT the generic-argument metadata for instantiated
    `IEquatable<T>` interfaces on test types is trimmed, so
    `GetGenericArguments()` returns an empty array and `[0]` throws
    `IndexOutOfRangeException` from inside NUnit. This breaks every
    `Assert.AreEqual` call on `Java.Lang.Object`-derived types or on
    common framework types like `DateTime`.

    Preserve metadata on the types most frequently compared by the test
    suite so that their `IEquatable<T>` interface implementations survive
    the AOT compiler. This file is only consumed when `$(PublishAot)` is
    `true` (see `Mono.Android.NET-Tests.csproj`).
  -->
  <assembly fullname="Mono.Android">
    <type fullname="Java.Lang.Object" preserve="all" />
    <type fullname="Java.Lang.Throwable" preserve="all" />
  </assembly>
</linker>
