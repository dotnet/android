<!-- Trimmable typemap targets for NativeAOT runtime.
     Adds generated typemap assemblies to ILC inputs. -->
<Project>

  <PropertyGroup>
    <_TrimmableRuntimeProviderJavaName Condition=" '$(_TrimmableRuntimeProviderJavaName)' == '' ">net.dot.jni.nativeaot.NativeAotRuntimeProvider</_TrimmableRuntimeProviderJavaName>
  </PropertyGroup>

  <!-- Before ILC input computation, add generated assemblies to ILC inputs.
       NOT as TrimmerRootAssembly — ILC must process TypeMapAttributes and trim entries
       whose trimTarget types were removed. -->
  <Target Name="_AddTrimmableTypeMapAssembliesToIlc"
      BeforeTargets="_AndroidComputeIlcCompileInputs"
      DependsOnTargets="_GenerateTrimmableTypeMap">
    <PropertyGroup>
      <TypeMapEntryAssembly>$(_TypeMapAssemblyName)</TypeMapEntryAssembly>
    </PropertyGroup>
    <ItemGroup>
      <_TrimmableTypeMapIlcAssemblies Include="$(_TypeMapOutputDirectory)*.dll" />
      <IlcReference Include="@(_TrimmableTypeMapIlcAssemblies)" />
      <UnmanagedEntryPointsAssembly Include="@(_TrimmableTypeMapIlcAssemblies->'%(Filename)')" />
    </ItemGroup>
  </Target>

</Project>
