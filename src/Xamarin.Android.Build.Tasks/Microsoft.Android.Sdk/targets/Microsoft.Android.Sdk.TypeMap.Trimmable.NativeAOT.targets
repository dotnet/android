<!-- Trimmable typemap targets for NativeAOT runtime.
     Adds generated typemap assemblies to ILC inputs. -->
<Project>

  <PropertyGroup>
    <_TrimmableRuntimeProviderJavaName Condition=" '$(_TrimmableRuntimeProviderJavaName)' == '' ">net.dot.jni.nativeaot.NativeAotRuntimeProvider</_TrimmableRuntimeProviderJavaName>
  </PropertyGroup>

  <!-- Add generated typemap assemblies to ILC inputs.
       NOT as TrimmerRootAssembly — ILC must process TypeMapAttributes and trim entries
       whose trimTarget types were removed. -->
  <Target Name="_AddTrimmableTypeMapAssembliesToIlc"
      AfterTargets="_AndroidComputeIlcCompileInputs"
      BeforeTargets="WriteIlcRspFileForCompilation"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <PropertyGroup>
      <TypeMapEntryAssembly Condition=" '$(TypeMapEntryAssembly)' == '' ">_$(AssemblyName).TypeMap</TypeMapEntryAssembly>
    </PropertyGroup>
    <ItemGroup>
      <_TrimmableTypeMapAssembliesForIlc Include="$(_TypeMapOutputDirectory)*.dll" />
      <IlcCompileInput Include="@(_TrimmableTypeMapAssembliesForIlc->'%(FullPath)')" />
      <IlcReference Include="@(_TrimmableTypeMapAssembliesForIlc->'%(FullPath)')" />
      <UnmanagedEntryPointsAssembly Include="@(_TrimmableTypeMapAssembliesForIlc->'%(Filename)')" />
    </ItemGroup>
  </Target>

</Project>
