<!-- Trimmable typemap: CoreCLR-specific (ILLink integration). -->
<Project>

  <!-- Add TypeMap DLLs to ILLink input. ILLink natively understands TypeMapAttribute<T>. -->
  <Target Name="_AddTrimmableTypeMapToLinker"
      BeforeTargets="PrepareForILLink;_RunILLink"
      DependsOnTargets="_GenerateTrimmableTypeMap"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <ItemGroup>
      <ManagedAssemblyToLink Include="$(_TypeMapOutputDirectory)*.dll">
        <DestinationSubPath>%(Filename)%(Extension)</DestinationSubPath>
      </ManagedAssemblyToLink>
    </ItemGroup>
  </Target>

  <!-- Pass TypeMap entry assembly name to ILLink -->
  <Target Name="_ConfigureTrimmableTypeMapForLinker"
      BeforeTargets="PrepareForILLink;_RunILLink"
      DependsOnTargets="_GenerateTrimmableTypeMap"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <PropertyGroup>
      <_ExtraTrimmerArgs>--typemap-entry-assembly $(_TypeMapAssemblyName) $(_ExtraTrimmerArgs)</_ExtraTrimmerArgs>
    </PropertyGroup>
  </Target>

  <!-- Add TRIMMED TypeMap DLLs to assembly store with per-ABI metadata.
       Reads from linked/ (ILLink output, inner builds have completed by now). -->
  <Target Name="_AddTrimmableTypeMapAssembliesToStore"
      BeforeTargets="_BuildApkEmbed"
      DependsOnTargets="_GenerateJavaStubs;_DefineBuildTargetAbis"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <!-- Derive ABI → RID mapping from the ABIs selected for this build -->
    <ItemGroup>
      <_TypeMapAbiRid Include="@(_BuildTargetAbis)" />
      <_TypeMapAbiRid Update="arm64-v8a"><Rid>android-arm64</Rid></_TypeMapAbiRid>
      <_TypeMapAbiRid Update="x86_64"><Rid>android-x64</Rid></_TypeMapAbiRid>
    </ItemGroup>
    <!-- MSBuild batches over _TypeMapAbiRid: for each ABI, glob linked TypeMap DLLs and add them to the store -->
    <ItemGroup>
      <_BuildApkResolvedUserAssemblies
          Include="$(IntermediateOutputPath)%(_TypeMapAbiRid.Rid)\linked\_*.TypeMap.dll;$(IntermediateOutputPath)%(_TypeMapAbiRid.Rid)\linked\_Microsoft.Android.TypeMaps.dll">
        <Abi>%(_TypeMapAbiRid.Identity)</Abi>
        <RuntimeIdentifier>%(_TypeMapAbiRid.Rid)</RuntimeIdentifier>
        <DestinationSubPath>%(_TypeMapAbiRid.Identity)/%(Filename)%(Extension)</DestinationSubPath>
        <DestinationSubDirectory>%(_TypeMapAbiRid.Identity)/</DestinationSubDirectory>
      </_BuildApkResolvedUserAssemblies>
    </ItemGroup>
  </Target>

</Project>
