<!-- Trimmable typemap: CoreCLR-specific (ILLink integration). -->
<Project>

  <!-- Add TypeMap DLLs to ILLink input. ILLink natively understands TypeMapAttribute<T>. -->
  <Target Name="_AddTrimmableTypeMapToLinker"
      BeforeTargets="PrepareForILLink;_RunILLink"
      DependsOnTargets="_GenerateTrimmableTypeMap"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <ItemGroup>
      <ManagedAssemblyToLink Include="$(_TypeMapOutputDirectory)*.dll">
        <DestinationSubPath>%(Filename)%(Extension)</DestinationSubPath>
      </ManagedAssemblyToLink>
    </ItemGroup>
  </Target>

  <!-- Pass TypeMap entry assembly name to ILLink -->
  <Target Name="_ConfigureTrimmableTypeMapForLinker"
      BeforeTargets="PrepareForILLink;_RunILLink"
      DependsOnTargets="_GenerateTrimmableTypeMap"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <PropertyGroup>
      <_ExtraTrimmerArgs>--typemap-entry-assembly $(_TypeMapAssemblyName) $(_ExtraTrimmerArgs)</_ExtraTrimmerArgs>
    </PropertyGroup>
  </Target>

  <!-- Add TRIMMED TypeMap DLLs to assembly store with per-ABI metadata.
       Reads from linked/ (ILLink output, inner builds have completed by now). -->
  <Target Name="_AddTrimmableTypeMapAssembliesToStore"
      BeforeTargets="_BuildApkEmbed"
      DependsOnTargets="_GenerateJavaStubs"
      Condition=" '$(_AndroidTypeMapImplementation)' == 'trimmable' ">
    <ItemGroup>
      <_LinkedTypeMapDlls Remove="@(_LinkedTypeMapDlls)" />
      <_LinkedTypeMapDlls Include="$(IntermediateOutputPath)android-arm64\linked\_*.TypeMap.dll;$(IntermediateOutputPath)android-arm64\linked\_Microsoft.Android.TypeMaps.dll" />
    </ItemGroup>
    <ItemGroup Condition=" '@(_LinkedTypeMapDlls)' != '' ">
      <_BuildApkResolvedUserAssemblies Include="@(_LinkedTypeMapDlls)">
        <Abi>arm64-v8a</Abi>
        <RuntimeIdentifier>android-arm64</RuntimeIdentifier>
        <DestinationSubPath>arm64-v8a/%(Filename)%(Extension)</DestinationSubPath>
        <DestinationSubDirectory>arm64-v8a/</DestinationSubDirectory>
      </_BuildApkResolvedUserAssemblies>
    </ItemGroup>
    <ItemGroup>
      <_LinkedTypeMapDlls Remove="@(_LinkedTypeMapDlls)" />
      <_LinkedTypeMapDlls Include="$(IntermediateOutputPath)android-x64\linked\_*.TypeMap.dll;$(IntermediateOutputPath)android-x64\linked\_Microsoft.Android.TypeMaps.dll" />
    </ItemGroup>
    <ItemGroup Condition=" '@(_LinkedTypeMapDlls)' != '' ">
      <_BuildApkResolvedUserAssemblies Include="@(_LinkedTypeMapDlls)">
        <Abi>x86_64</Abi>
        <RuntimeIdentifier>android-x64</RuntimeIdentifier>
        <DestinationSubPath>x86_64/%(Filename)%(Extension)</DestinationSubPath>
        <DestinationSubDirectory>x86_64/</DestinationSubDirectory>
      </_BuildApkResolvedUserAssemblies>
    </ItemGroup>
  </Target>

</Project>
