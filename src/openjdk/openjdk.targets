<Project>

  <!-- Determine platform-specific download properties -->
  <PropertyGroup Condition=" '$(HostOS)' == 'Windows' ">
    <_OpenJDKPlatform>windows-x64</_OpenJDKPlatform>
    <_OpenJDKExtension>.zip</_OpenJDKExtension>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(HostOS)' == 'Linux' ">
    <_OpenJDKPlatform>linux-x64</_OpenJDKPlatform>
    <_OpenJDKExtension>.tar.gz</_OpenJDKExtension>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(HostOS)' == 'Darwin' And '$(HostOSArchitecture)' != 'Arm64' ">
    <_OpenJDKPlatform>macos-x64</_OpenJDKPlatform>
    <_OpenJDKExtension>.tar.gz</_OpenJDKExtension>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(HostOS)' == 'Darwin' And '$(HostOSArchitecture)' == 'Arm64' ">
    <_OpenJDKPlatform>macos-aarch64</_OpenJDKPlatform>
    <_OpenJDKExtension>.tar.gz</_OpenJDKExtension>
  </PropertyGroup>

  <PropertyGroup>
    <_OpenJDKFileName>microsoft-jdk-$(MicrosoftOpenJDKVersion)-$(_OpenJDKPlatform)$(_OpenJDKExtension)</_OpenJDKFileName>
    <_OpenJDKHashFileName>$(_OpenJDKFileName).sha256sum.txt</_OpenJDKHashFileName>
    <_OpenJDKArchiveUrl>https://aka.ms/download-jdk/$(_OpenJDKFileName)</_OpenJDKArchiveUrl>
    <_OpenJDKHashUrl>$(_OpenJDKArchiveUrl).sha256sum.txt</_OpenJDKHashUrl>
    <_OpenJDKArchive>$(AndroidToolchainCacheDirectory)\$(_OpenJDKFileName)</_OpenJDKArchive>
    <_OpenJDKHashFile>$(AndroidToolchainCacheDirectory)\$(_OpenJDKHashFileName)</_OpenJDKHashFile>
    <_OpenJDKExtractDir>$(AndroidToolchainCacheDirectory)\openjdk-$(MicrosoftOpenJDKVersion)</_OpenJDKExtractDir>
    <_OpenJDKInstallDir>$(AndroidToolchainDirectory)\$(MicrosoftOpenJDKFolder)</_OpenJDKInstallDir>
    <_OpenJDKVersionFile>$(_OpenJDKInstallDir)\xa_jdk_version.txt</_OpenJDKVersionFile>
    <!-- On macOS, the tar.gz extracts with Contents/Home subdirectory -->
    <_OpenJDKExtractSubdir Condition=" '$(HostOS)' != 'Darwin' ">$(_OpenJDKExtractDir)\$(MicrosoftOpenJDKRootDirName)</_OpenJDKExtractSubdir>
    <_OpenJDKExtractSubdir Condition=" '$(HostOS)' == 'Darwin' ">$(_OpenJDKExtractDir)\$(MicrosoftOpenJDKRootDirName)\Contents\Home</_OpenJDKExtractSubdir>
  </PropertyGroup>

  <Target Name="_DownloadOpenJDK"
      Inputs="$(MSBuildThisFileFullPath);$(MSBuildProjectFullPath);..\..\Configuration.props"
      Outputs="$(_OpenJDKArchive)">
    <DownloadFile
        SourceUrl="$(_OpenJDKArchiveUrl)"
        DestinationFolder="$(AndroidToolchainCacheDirectory)"
        DestinationFileName="$(_OpenJDKFileName)"
        Retries="3"
    />
    <!-- Download the SHA-256 hash file from Microsoft and parse the expected hash.
         File format: "6ecfa864...  microsoft-jdk-21.0.8-windows-x64.zip" -->
    <DownloadFile
        SourceUrl="$(_OpenJDKHashUrl)"
        DestinationFolder="$(AndroidToolchainCacheDirectory)"
        DestinationFileName="$(_OpenJDKHashFileName)"
        Retries="3"
    />
    <PropertyGroup>
      <_OpenJDKExpectedHash>$([System.IO.File]::ReadAllText('$(_OpenJDKHashFile)').Substring(0, 64).ToUpperInvariant())</_OpenJDKExpectedHash>
    </PropertyGroup>
    <GetFileHash Files="$(_OpenJDKArchive)" Algorithm="SHA256">
      <Output TaskParameter="Hash" PropertyName="_OpenJDKActualHash" />
    </GetFileHash>
    <Delete
        Condition=" '$(_OpenJDKActualHash)' != '$(_OpenJDKExpectedHash)' "
        Files="$(_OpenJDKArchive);$(_OpenJDKHashFile)"
    />
    <Error
        Condition=" '$(_OpenJDKActualHash)' != '$(_OpenJDKExpectedHash)' "
        Text="SHA256 mismatch for $(_OpenJDKFileName). Expected: $(_OpenJDKExpectedHash) Actual: $(_OpenJDKActualHash)"
    />
  </Target>

  <Target Name="_ExtractOpenJDK"
      DependsOnTargets="_DownloadOpenJDK"
      Inputs="$(_OpenJDKArchive)"
      Outputs="$(_OpenJDKExtractDir)\.extracted">
    <RemoveDir Directories="$(_OpenJDKExtractDir)" />
    <MakeDir Directories="$(_OpenJDKExtractDir)" />
    <!-- Windows: use built-in Unzip task -->
    <Unzip
        Condition=" '$(HostOS)' == 'Windows' "
        SourceFiles="$(_OpenJDKArchive)"
        DestinationFolder="$(_OpenJDKExtractDir)"
        OverwriteReadOnlyFiles="true"
    />
    <!-- Linux/macOS: use tar -->
    <Exec
        Condition=" '$(HostOS)' != 'Windows' "
        Command="tar xzf &quot;$(_OpenJDKArchive)&quot; -C &quot;$(_OpenJDKExtractDir)&quot;"
    />
    <Touch Files="$(_OpenJDKExtractDir)\.extracted" AlwaysCreate="true" />
  </Target>

  <Target Name="_InstallOpenJDK"
      BeforeTargets="Build"
      DependsOnTargets="_ExtractOpenJDK"
      Inputs="$(_OpenJDKExtractDir)\.extracted"
      Outputs="$(_OpenJDKVersionFile)">
    <ItemGroup>
      <_OpenJDKFiles Include="$(_OpenJDKExtractSubdir)\**\*" />
    </ItemGroup>
    <Error
        Condition=" '@(_OpenJDKFiles)' == '' "
        Text="OpenJDK root directory not found after extraction. Expected: $(_OpenJDKExtractSubdir)"
    />
    <!-- Remove old install to avoid stale files from previous versions -->
    <RemoveDir Directories="$(_OpenJDKInstallDir)" />
    <MakeDir Directories="$(_OpenJDKInstallDir)" />
    <Copy
        SourceFiles="@(_OpenJDKFiles)"
        DestinationFiles="@(_OpenJDKFiles->'$(_OpenJDKInstallDir)\%(RecursiveDir)%(Filename)%(Extension)')"
        SkipUnchangedFiles="true"
    />
    <!-- Verify key JDK files exist after installation -->
    <Error
        Condition=" !Exists('$(_OpenJDKInstallDir)\bin\javac') And !Exists('$(_OpenJDKInstallDir)\bin\javac.exe') "
        Text="JDK installation is missing bin\javac in $(_OpenJDKInstallDir)"
    />
    <Error
        Condition=" !Exists('$(_OpenJDKInstallDir)\bin\java') And !Exists('$(_OpenJDKInstallDir)\bin\java.exe') "
        Text="JDK installation is missing bin\java in $(_OpenJDKInstallDir)"
    />
    <Error
        Condition=" !Exists('$(_OpenJDKInstallDir)\include\jni.h') "
        Text="JDK installation is missing include\jni.h in $(_OpenJDKInstallDir)"
    />
    <WriteLinesToFile
        File="$(_OpenJDKVersionFile)"
        Lines="$(MicrosoftOpenJDKVersion)"
        Overwrite="true"
    />
  </Target>

  <Target Name="_CleanOpenJDK" BeforeTargets="Clean">
    <RemoveDir Directories="$(_OpenJDKExtractDir);$(_OpenJDKInstallDir)" />
    <Delete Files="$(_OpenJDKArchive);$(_OpenJDKHashFile)" />
  </Target>

</Project>
