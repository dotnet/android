<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(MSBuildThisFileDirectory)..\..\Configuration.props" />
  <PropertyGroup>
    <NoWarn>$(NoWarn);CA1305;CS1591</NoWarn>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>12</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <DefineConstants Condition=" '$(OS)' == 'Windows_NT' ">WINDOWS;$(DefineConstants)</DefineConstants>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <OutputPath>$(MicrosoftAndroidSdkOutDir)</OutputPath>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DocumentationFile>bin\Debug\Xamarin.Installer.AndroidSDK.xml</DocumentationFile>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DocumentationFile>bin\Release\Xamarin.Installer.AndroidSDK.xml</DocumentationFile>
  </PropertyGroup>
  <!-- This is for the installer, but can be made more generic if need be -->
  <Import Project="..\..\..\BuildOptions.props" Condition=" Exists('..\..\..\BuildOptions.props') " />
  <PropertyGroup Condition="'$(CodeSigningFile)' != ''">
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>$(CodeSigningFile)</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <PropertyGroup Label="NuGet">
    <PackageId>Xamarin.Installer.AndroidSDK</PackageId>
    <Description>Assembly for Xamarin.Installer.AndroidSDK</Description>
  </PropertyGroup>
  <ItemGroup>
    <None Remove="tests\**" />
    <Compile Remove="tests\**" />
    <Compile Include="..\Xamarin.Installer.Common\Properties\AssemblyInfoTemplate.cs">
      <Link>Properties\AssemblyInfoTemplate.cs</Link>
    </Compile>
    <Compile Update="Properties\Resources.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Update="Properties\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Mono.AndroidTools\Mono.AndroidTools.csproj" />
    <ProjectReference Include="..\Xamarin.AndroidTools\Xamarin.AndroidTools.csproj" />
    <ProjectReference Include="..\Xamarin.Installer.Common\Xamarin.Installer.Common.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="GitInfo" Version="$(GitInfoVersion)" />
    <PackageReference Include="ini-parser-netstandard" Version="$(IniParserNetstandardVersion)" />
    <PackageReference Include="Mono.Unix" Version="$(MonoUnixVersion)" Condition=" '$(OS)' != 'Windows_NT' " />
    <PackageReference Include="Polly" Version="$(PollyVersion)">
      <ExcludeAssets Condition=" '$(PublicPolly)' == '' ">runtime</ExcludeAssets>
      <PrivateAssets Condition=" '$(PublicPolly)' == '' ">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="SharpZipLib" Version="$(SharpZipLibVersion)">
      <ExcludeAssets Condition=" '$(PublicSharpZipLib)' == '' ">runtime</ExcludeAssets>
      <PrivateAssets Condition=" '$(PublicSharpZipLib)' == '' ">All</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.VisualStudioEng.MicroBuild.Core">
      <Version>1.0.0</Version>
    </PackageReference>
    <PackageReference Include="System.Text.Encoding.CodePages" Version="$(SystemTextEncodingCodePagesVersion)" />
  </ItemGroup>
  <ProjectExtensions>
    <MonoDevelop>
      <Properties>
        <Policies>
          <DotNetNamingPolicy ResourceNamePolicy="FileFormatDefault" DirectoryNamespaceAssociation="PrefixedFlat" />
        </Policies>
      </Properties>
    </MonoDevelop>
  </ProjectExtensions>
  <PropertyGroup Condition="'$(GitVersionFile)' == ''">
    <GitVersionFile>$(MSBuildThisFileDirectory)..\..\build-tools\android-platform-support\version.txt</GitVersionFile>
  </PropertyGroup>
  <Import Project="CodeGenerator.targets" />
  <Import Project="$(MSBuildThisFileDirectory)..\automation\nuget\AndroidSdkInstaller.Versions.targets" Condition="Exists('$(MSBuildThisFileDirectory)..\automation\nuget\AndroidSdkInstaller.Versions.targets') And '$(AndroidSdkInstallerVersionsTargetsImported)' != 'true'" />
  <ItemGroup>
    <PackageFile Include="$(OutDir)\$(AssemblyName).dll" PackagePath="bin\$(TargetFramework)\$(AssemblyName).dll" />
  </ItemGroup>

  <Target Name="GetFilesToSign" BeforeTargets="SignFiles" Condition=" '$(SignSdkManager)' == 'true' ">
    <ItemGroup>
      <FilesToSign Include="$(IntermediateOutputPath)\**\$(AssemblyName).resources.dll">
        <Authenticode>Microsoft400</Authenticode>
      </FilesToSign>
      <FilesToSign Include="$(OutDir)\$(AssemblyName).dll"> 
        <Authenticode>Microsoft400</Authenticode> 
      </FilesToSign>
    </ItemGroup>
  </Target>

</Project>
