<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net11.0-android36.1</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>HelloTrimmable</RootNamespace>
    <UseMonoRuntime>false</UseMonoRuntime>
    <_AndroidTypeMapImplementation>trimmable</_AndroidTypeMapImplementation>
    <RunAOTCompilation>false</RunAOTCompilation>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
  <ItemGroup>
    <RuntimeHostConfigurationOption Include="Microsoft.Android.Runtime.RuntimeFeature.TrimmableTypeMap" Value="true" Trim="true" />
    <RuntimeHostConfigurationOption Include="System.Runtime.InteropServices.TypeMappingEntryAssembly" Value="_Microsoft.Android.TypeMaps" />
  </ItemGroup>
  <ItemGroup>
    <TrimmerRootDescriptor Include="LinkerDescriptor.xml" />
  </ItemGroup>
</Project>
